                </value>
                <value>
                    <fullName>Failed - Hazard</fullName>
                    <default>false</default>
                    <label>Failed - Hazard</label>
                </value>
                <value>
                    <fullName>Wear and Tear</fullName>
                    <default>false</default>
                    <label>Wear and Tear</label>
                </value>
                <value>
                    <fullName>Closed</fullName>
                    <default>false</default>
                    <label>Closed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
